# Database Configuration
DATABASE_URL="postgresql://dot_mag_user:dot_mag_password@localhost:5432/dot_mag"

# PostgreSQL Docker Configuration
POSTGRES_USER=dot_mag_user
POSTGRES_PASSWORD=dot_mag_password
POSTGRES_DB=dot_mag

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_min_32_characters_required

# App Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
INTERNAL_API_BASE_URL="http://127.0.0.1:3000"

# Chat Realtime (WebSocket)
# Optional explicit websocket base URL (no path), e.g. wss://dotmag.ir
# Leave empty to auto-use current domain and protocol.
NEXT_PUBLIC_CHAT_WS_URL=
# Optional strict origin check for websocket handshake, e.g. https://example.com
CHAT_WS_ALLOWED_ORIGIN=
# Optional websocket path (must match client path suffix)
CHAT_WS_PATH=/ws/chat

# Android App (for TWA signing)
ANDROID_SHA256_FINGERPRINT=your_android_sha256_here
