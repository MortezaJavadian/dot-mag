// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  username  String     @unique
  password  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Article {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String   @db.Text
  content     String   @db.Text
  category    String
  tags        Tag[]
  image       String
  publishedAt String
  sortDate    DateTime @default(now())
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  articles  Article[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Magazine {
  id          String          @id @default(cuid())
  slug        String          @unique
  title       String
  subtitle    String
  description String          @db.Text
  cover       String?         @db.Text
  pdfUrl      String?         @db.Text
  publishedAt String
  sortDate    DateTime        @default(now())
  pageCount   Int
  pages       MagazinePage[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model MagazinePage {
  id        String   @id @default(cuid())
  magazine  Magazine @relation(fields: [magazineId], references: [id], onDelete: Cascade)
  magazineId String
  number    Int
  type      String
  image     String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([magazineId, number])
}

model Radio {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  intro       String         @db.Text
  cover       String?        @db.Text
  audioUrl    String         @db.Text
  publishedAt String
  sortDate    DateTime       @default(now())
  durationSec Int?
  segments    RadioSegment[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model RadioSegment {
  id          String   @id @default(cuid())
  radio       Radio    @relation(fields: [radioId], references: [id], onDelete: Cascade)
  radioId     String
  number      Int
  title       String
  audioUrl    String   @db.Text
  durationSec Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([radioId, number])
}
