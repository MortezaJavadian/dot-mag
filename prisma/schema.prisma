// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  username  String     @unique
  password  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Article {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String   @db.Text
  content     String   @db.Text
  category    String
  tags        Tag[]
  personId    String?
  person      Person?  @relation(fields: [personId], references: [id], onDelete: SetNull)
  image       String
  publishedAt String
  sortDate    DateTime @default(now())
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  sortOrder Int       @default(0)
  articles  Article[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Magazine {
  id          String          @id @default(cuid())
  slug        String          @unique
  title       String
  subtitle    String
  description String          @db.Text
  cover       String?         @db.Text
  pdfUrl      String?         @db.Text
  publishedAt String
  sortDate    DateTime        @default(now())
  pageCount   Int
  pages       MagazinePage[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model MagazinePage {
  id        String   @id @default(cuid())
  magazine  Magazine @relation(fields: [magazineId], references: [id], onDelete: Cascade)
  magazineId String
  number    Int
  type      String
  image     String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([magazineId, number])
}

model Radio {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  summary     String?        @db.Text
  intro       String         @db.Text
  personId    String?
  person      Person?        @relation(fields: [personId], references: [id], onDelete: SetNull)
  cover       String?        @db.Text
  audioUrl    String         @db.Text
  audioUrlLow String?        @db.Text
  audioUrlMedium String?     @db.Text
  audioUrlHigh String?       @db.Text
  audioSizeLow Int?
  audioSizeMedium Int?
  audioSizeHigh Int?
  playerAudioQuality String  @default("high")
  publishedAt String
  sortDate    DateTime       @default(now())
  durationSec Int?
  segments    RadioSegment[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model RadioSegment {
  id          String   @id @default(cuid())
  radio       Radio    @relation(fields: [radioId], references: [id], onDelete: Cascade)
  radioId     String
  number      Int
  title       String
  summary     String?  @db.Text
  audioUrl    String   @db.Text
  durationSec Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([radioId, number])
}

model HomeHeroConfigStore {
  id                 String   @id
  badgeText          String
  heroHtml           String   @db.Text
  secondLineAsTitle  Boolean  @default(true)
  featuredArticleIds Json
  image              String?  @db.Text
  ctaMode            String   @default("none")
  ctaTargetId        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Person {
  id              String    @id @default(cuid())
  name            String
  image           String    @db.Text
  bio             String    @db.Text
  isDotTeamMember Boolean   @default(false)
  sortOrder       Int       @default(0)
  articles        Article[]
  radios          Radio[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
